# --- Helper Functions for Interactive Prompts ---
def prompt_choice(question, options, default=1):
    print(f"\n{Colors.BOLD}{Colors.CYAN}? {question}{Colors.ENDC}")
    for idx, opt in enumerate(options, 1):
        def_str = f" (default)" if idx == default else ""
        print(f"  {Colors.GREEN}{idx}){Colors.ENDC} {opt}{def_str}")
    
    while True:
        try:
            choice = input(f"Select (1-{len(options)}) [{default}]: ").strip()
            if not choice:
                return default
            val = int(choice)
            if 1 <= val <= len(options):
                return val
            print(f"{Colors.FAIL}Please enter a number between 1 and {len(options)}.{Colors.ENDC}")
        except ValueError:
            print(f"{Colors.FAIL}Invalid input. Please enter a number.{Colors.ENDC}")

def prompt_yes_no(question, default=True):
    def_str = " [Y/n]" if default else " [y/N]"
    print(f"{Colors.BOLD}{Colors.CYAN}? {question}{def_str}{Colors.ENDC}", end=" ")
    while True:
        choice = input().strip().lower()
        if not choice:
            return default
        if choice in ['y', 'yes']:
            return True
        if choice in ['n', 'no']:
            return False
        print(f"{Colors.FAIL}Please enter y or n.{Colors.ENDC} ", end="")

def prompt_text(question, default=""):
    def_str = f" [{default}]" if default else ""
    print(f"{Colors.BOLD}{Colors.CYAN}? {question}{def_str}:{Colors.ENDC}", end=" ")
    val = input().strip()
    return val if val else default

def prompt_password(question, confirm=True):
    while True:
        p1 = getpass.getpass(f"{Colors.BOLD}{Colors.CYAN}? {question}:{Colors.ENDC} ")
        if not p1:
            print(f"{Colors.FAIL}Password cannot be empty.{Colors.ENDC}")
            continue
        if not confirm:
            return p1
        p2 = getpass.getpass(f"{Colors.BOLD}{Colors.CYAN}? Confirm password:{Colors.ENDC} ")
        if p1 == p2:
            return p1
        print(f"{Colors.FAIL}Passwords do not match. Try again.{Colors.ENDC}")

# --- Core Logic Functions ---

def get_removable_disks():
    """Queries connected block devices using lsblk."""
    try:
        res = subprocess.run(["lsblk", "-o", "NAME,FSTYPE,LABEL,SIZE,MOUNTPOINT,MODEL,TRAN,RM", "-J"], capture_output=True, text=True, check=True)
        data = json.loads(res.stdout)
    except Exception as e:
        print_warning(f"Failed to query block devices using lsblk JSON: {e}")
        return []
        
    devices = []
    for dev in data.get("blockdevices", []):
        is_removable = dev.get("rm") or dev.get("tran") == "usb"
        
        mounts = []
        if dev.get("mountpoint"):
            mounts.append(dev["mountpoint"])
        
        has_root_mount = dev.get("mountpoint") == "/"
        
        children = dev.get("children", [])
        for child in children:
            if child.get("mountpoint"):
                mounts.append(child["mountpoint"])
                if child.get("mountpoint") == "/":
                    has_root_mount = True
                    
        if has_root_mount:
            continue
            
        devices.append({
            "name": dev.get("name"),
            "model": dev.get("model") or "Unknown Model",
            "size": dev.get("size"),
            "tran": dev.get("tran") or "N/A",
            "removable": is_removable,
            "mounts": mounts,
            "path": f"/dev/{dev.get('name')}"
        })
    return devices

def hash_password(password):
    """Securely hashes a plaintext password using openssl passwd -6."""
    try:
        proc = subprocess.run(
            ["openssl", "passwd", "-6", "--stdin"],
            input=password,
            capture_output=True,
            text=True,
            check=True
        )
        return proc.stdout.strip()
    except Exception as e:
        raise RuntimeError("Failed to generate password hash using OpenSSL. Please ensure openssl is installed.") from e

def get_local_ssh_keys():
    """Finds SSH public keys in ~/.ssh/."""
    home = os.path.expanduser("~")
    pub_files = glob.glob(os.path.join(home, ".ssh", "*.pub"))
    keys = []
    for filepath in pub_files:
        try:
            with open(filepath, "r") as f:
                content = f.read().strip()
                if content:
                    keys.append((os.path.basename(filepath), content))
        except Exception:
            pass
    return keys

def get_github_ssh_keys(username):
    """Fetches public keys from GitHub."""
    url = f"https://github.com/{username}.keys"
    try:
        req = urllib.request.Request(
            url, 
            headers={"User-Agent": "Mozilla/5.0"}
        )
        with urllib.request.urlopen(req) as response:
            content = response.read().decode().strip()
            if response.status == 200 and content:
                return [line.strip() for line in content.splitlines() if line.strip()]
    except Exception as e:
        raise RuntimeError(f"Failed to fetch keys for GitHub user '{username}': {e}")
    return []

# --- Official Image Management ---

OFFICIAL_OS_LIST_URL = "https://downloads.raspberrypi.org/os_list_imagingutility_v4.json"

def get_cached_os_list_path():
    home = os.path.expanduser("~")
    cache_dir = os.path.join(home, ".cache", "rpi-flash")
    os.makedirs(cache_dir, exist_ok=True)
    return os.path.join(cache_dir, "os_list.json")

def fetch_official_os_list(force=False):
    """Downloads or reads cached OS list JSON."""
    cache_path = get_cached_os_list_path()
    # Cache for 24 hours
    if not force and os.path.exists(cache_path) and (time.time() - os.path.getmtime(cache_path) < 86400):
        try:
            with open(cache_path, "r") as f:
                return json.load(f)
        except Exception:
            pass
            
    print(f"{Colors.BLUE}Fetching official Raspberry Pi OS catalog...{Colors.ENDC}")
    try:
        req = urllib.request.Request(
            OFFICIAL_OS_LIST_URL,
            headers={"User-Agent": "Mozilla/5.0"}
        )
        with urllib.request.urlopen(req) as response:
            data = json.loads(response.read().decode())
            with open(cache_path, "w") as f:
                json.dump(data, f)
            return data
    except Exception as e:
        print_warning(f"Could not fetch online OS catalog: {e}. Using local cache if available.")
        if os.path.exists(cache_path):
            with open(cache_path, "r") as f:
                return json.load(f)
        else:
            raise RuntimeError("OS catalog is unavailable and no local cache exists.")

def flatten_os_list(os_list, category=""):
    flat_list = []
    for item in os_list:
        name = item.get("name")
        full_name = f"{category} > {name}" if category else name
        if "subitems" in item:
            flat_list.extend(flatten_os_list(item["subitems"], category=full_name))
        elif "url" in item:
            flat_list.append({
                "name": name,
                "full_category": category,
                "description": item.get("description", ""),
                "url": item.get("url"),
                "extract_size": item.get("extract_size"),
                "extract_sha256": item.get("extract_sha256"),
                "image_download_size": item.get("image_download_size"),
                "devices": item.get("devices", [])
            })
    return flat_list

def download_file(url, dest_path, expected_size=None):
    """Downloads a file showing progress."""
    print(f"{Colors.BLUE}Downloading: {url}{Colors.ENDC}")
    print(f"Destination: {dest_path}")
    
    os.makedirs(os.path.dirname(dest_path), exist_ok=True)
    block_size = 1024 * 1024
    start_time = time.time()
    
    try:
        req = urllib.request.Request(
            url, 
            headers={"User-Agent": "Mozilla/5.0"}
        )
        with urllib.request.urlopen(req) as response:
            total_size = response.info().get("Content-Length")
            if total_size is not None:
                total_size = int(total_size)
            elif expected_size is not None:
                total_size = expected_size
            
            bytes_downloaded = 0
            with open(dest_path, "wb") as f:
                while True:
                    buffer = response.read(block_size)
                    if not buffer:
                        break
                    f.write(buffer)
                    bytes_downloaded += len(buffer)
                    
                    if total_size:
                        percent = (bytes_downloaded / total_size) * 100
                        elapsed = time.time() - start_time
                        speed = (bytes_downloaded / (1024 * 1024)) / elapsed if elapsed > 0 else 0
                        bar_len = 30
                        filled_len = int(bar_len * bytes_downloaded // total_size)
                        bar = "█" * filled_len + "░" * (bar_len - filled_len)
                        
                        sys.stdout.write(f"\r[{bar}] {percent:.1f}% ({speed:.1f} MB/s) - {bytes_downloaded / (1024*1024):.1f}/{total_size / (1024*1024):.1f} MB")
                        sys.stdout.flush()
                    else:
                        sys.stdout.write(f"\rDownloaded {bytes_downloaded / (1024*1024):.1f} MB...")
                        sys.stdout.flush()
            print(f"\n{Colors.GREEN}✔ Download complete!{Colors.ENDC}")
    except KeyboardInterrupt:
        print(f"\n{Colors.FAIL}✘ Download cancelled.{Colors.ENDC}")
        if os.path.exists(dest_path):
            os.remove(dest_path)
        sys.exit(1)
    except Exception as e:
        print(f"\n{Colors.FAIL}✘ Error downloading file: {e}{Colors.ENDC}")
        if os.path.exists(dest_path):
            os.remove(dest_path)
        sys.exit(1)

def verify_sha256(filepath, expected_sha):
    """Verifies file hash."""
    if not expected_sha:
        return True
    sha256 = hashlib.sha256()
    print("Verifying file integrity...")
    try:
        with open(filepath, 'rb') as f:
            while chunk := f.read(1024 * 1024):
                sha256.update(chunk)
        calculated = sha256.hexdigest()
        if calculated == expected_sha:
            print_success("Integrity verified (SHA-256 matches).")
            return True
        else:
            print_error(f"Integrity verification failed!\nExpected: {expected_sha}\nGot:      {calculated}")
            return False
    except Exception as e:
        print_error(f"Error during verification: {e}")
        return False

# --- Profile Management ---

def get_profiles_dir():
    home = os.path.expanduser("~")
    path = os.path.join(home, ".config", "rpi-flash", "profiles")
    os.makedirs(path, exist_ok=True)
    return path

def save_profile(name, config_data):
    pdir = get_profiles_dir()
    filepath = os.path.join(pdir, f"{name}.json")
    with open(filepath, "w") as f:
        json.dump(config_data, f, indent=2)
    print_success(f"Profile '{name}' saved to {filepath}")

def load_profile(name):
    pdir = get_profiles_dir()
    filepath = os.path.join(pdir, f"{name}.json")
    if not os.path.exists(filepath):
        raise FileNotFoundError(f"Profile '{name}' does not exist.")
    with open(filepath, "r") as f:
        return json.load(f)

def list_profiles():
    pdir = get_profiles_dir()
    files = glob.glob(os.path.join(pdir, "*.json"))
    return [os.path.basename(f)[:-5] for f in files]

def delete_profile(name):
    pdir = get_profiles_dir()
    filepath = os.path.join(pdir, f"{name}.json")
    if os.path.exists(filepath):
        os.remove(filepath)
        print_success(f"Deleted profile '{name}'")
    else:
        print_error(f"Profile '{name}' not found.")

